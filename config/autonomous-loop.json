{
  "enabled": true,
  "data_dir": "data",
  "state_path": "data/runs/autonomous-loop-state.json",
  "lock_path": "data/runs/autonomous-loop.lock",
  "lock_stale_minutes": 180,
  "health_stale_grace_hours": 6,
  "command_timeout_seconds": 240,
  "max_jobs_per_tick": 3,
  "send_telegram": false,
  "failure_issue_reporting": {
    "enabled": false,
    "repo": "kiku-jw/kikuai-github-scanner",
    "labels": ["opportunity-scanner", "autonomous-loop", "type:failure"]
  },
  "jobs": [
    {
      "id": "github-monitor-daily",
      "type": "github-monitor",
      "enabled": true,
      "interval_hours": 24,
      "config": "config/github-monitor.json",
      "mirror_github_issues": true,
      "mirror_repo": "kiku-jw/kikuai-github-scanner",
      "mirror_verdicts": ["watchlist", "proof-card", "PRD-lite", "operator-proof-approved"],
      "sync_github_project": false,
      "project_owner": "kiku-jw",
      "project_number": 4,
      "send_telegram": false
    },
    {
      "id": "hn-demand-daily",
      "type": "hn-demand",
      "enabled": true,
      "interval_hours": 72,
      "feeds": ["askstories", "showstories"],
      "max_stories": 12,
      "comments_per_story": 3,
      "max_total_items": 60,
      "max_clusters": 5,
      "max_candidates": 2,
      "ingest": true,
      "post_pipeline": true,
      "deep_review_max_candidates": 3,
      "ecosystems_enrich": true,
      "ecosystems_max_candidates": 4,
      "repo_digest_batch": true,
      "repo_digest_max_candidates": 1,
      "repo_digest_max_files": 80,
      "repo_digest_max_bytes": 500000,
      "repo_digest_clone_timeout_seconds": 90,
      "mirror_github_issues": true,
      "mirror_repo": "kiku-jw/kikuai-github-scanner",
      "mirror_verdicts": ["watchlist", "proof-card", "PRD-lite", "operator-proof-approved"],
      "sync_github_project": false,
      "project_owner": "kiku-jw",
      "project_number": 4,
      "send_telegram": false
    },
    {
      "id": "reddit-demand-weekly",
      "type": "reddit-demand",
      "enabled": false,
      "interval_hours": 168,
      "subreddits": ["webdev", "SaaS", "indiehackers"],
      "sort": "hot",
      "max_posts_per_subreddit": 8,
      "comments_per_post": 4,
      "max_total_items": 60,
      "max_clusters": 5,
      "max_candidates": 2,
      "ingest": true,
      "post_pipeline": true,
      "deep_review_max_candidates": 3,
      "ecosystems_enrich": true,
      "ecosystems_max_candidates": 4,
      "repo_digest_batch": true,
      "repo_digest_max_candidates": 1,
      "repo_digest_max_files": 80,
      "repo_digest_max_bytes": 500000,
      "repo_digest_clone_timeout_seconds": 90,
      "mirror_github_issues": true,
      "mirror_repo": "kiku-jw/kikuai-github-scanner",
      "mirror_verdicts": ["watchlist", "proof-card", "PRD-lite", "operator-proof-approved"],
      "sync_github_project": false,
      "project_owner": "kiku-jw",
      "project_number": 4,
      "send_telegram": false
    },
    {
      "id": "telegram-feedback",
      "type": "telegram-feedback",
      "enabled": true,
      "interval_hours": 4
    }
  ]
}
